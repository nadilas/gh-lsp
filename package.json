{
  "name": "gh-lsp",
  "version": "0.1.0",
  "description": "GitHub Code Intelligence Browser Extension — LSP-powered hover type info, go-to-definition, and signature help on GitHub.com",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:chrome": "tsc --noEmit && vite build",
    "build:safari": "pnpm build && bash scripts/build-safari.sh",
    "build:all": "pnpm build && bash scripts/build-safari.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}' 'tests/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}' 'tests/**/*.{ts,tsx}'",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "screenshots": "npx tsx scripts/take-screenshots.ts",
    "build:zip": "pnpm build && cd dist/chrome && zip -r ../../gh-lsp-chrome.zip ."
  },
  "dependencies": {
    "dompurify": "^3.3.2",
    "marked": "^17.0.4",
    "preact": "^10.25.0",
    "web-tree-sitter": "^0.26.6",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.9.0",
    "@types/chrome": "^0.0.287",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.3.5",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.17.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.0",
    "tree-sitter-go": "^0.25.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.4.2",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
