{
  "name": "gh-lsp",
  "version": "0.1.0",
  "description": "GitHub Code Intelligence Browser Extension — LSP-powered hover type info, go-to-definition, and signature help on GitHub.com",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}' 'tests/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}' 'tests/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "preact": "^10.25.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^9.17.0",
    "@preact/preset-vite": "^2.9.0",
    "@types/chrome": "^0.0.287",
    "@types/webextension-polyfill": "^0.12.1",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.17.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
